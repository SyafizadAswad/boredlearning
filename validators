## Method 2: The Pro-Tip Approach (Custom Error Pipe)

If you have multiple fields, repeating those `*ngIf` blocks gets exhausting. You can create a **Custom Pipe** to handle the heavy lifting and keep your template beautiful.

### 1. Create the Pipe (`.ts`)

This pipe will take the `errors` object and return the first relevant error message.

```typescript
import { Pipe, PipeTransform } from '@angular/core';
import { ValidationErrors } from '@angular/forms';

@Component({ ... }) // Or standalone pipe

@Pipe({
  name: 'fieldError',
  pure: true
})
export class FieldErrorPipe implements PipeTransform {
  transform(errors: ValidationErrors | null | undefined): string {
    if (!errors) return '';

    if (errors['required']) return 'This field is required.';
    if (errors['maxlength']) return `Maximum length is ${errors['maxlength'].requiredLength} characters.`;
    if (errors['pattern']) return 'Invalid format/characters.';

    return 'Invalid field data.';
  }
}

```

### 2. Use it in HTML

Now your HTML is reduced to just a single, clean line:

```html
<input formControlName="username" />

<div *ngIf="username?.invalid && (username?.dirty || username?.touched)" class="error-msg">
  <small>{{ username?.errors | fieldError }}</small>
</div>

```

